# Audio Ally frontend (Vite). Copy this file to `.env` in the same folder as `package.json`.
# Never commit `.env` (real keys). This file is safe to commit.

# Optional: ElevenLabs (voice previews, TTS in learn flow)
# Get a key at https://elevenlabs.io
# VITE_ELEVENLABS_API_KEY=

# Gemini (PDF story generation, answer evaluation)
# If you only work on UI, leave these empty and browse the app; teammates can supply keys.
# Vite loads GEMINI_API_KEY or VITE_GEMINI_API_KEY (see vite.config.js; server key wins for dev).
# GEMINI_API_KEY=
# VITE_GEMINI_API_KEY=
# VITE_GEMINI_MODEL=gemini-2.0-flash
